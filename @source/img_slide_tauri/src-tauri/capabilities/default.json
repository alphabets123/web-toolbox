{
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "opener:default",
    "process:default",
    "fs:default",
    "dialog:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen"
  ]
}
