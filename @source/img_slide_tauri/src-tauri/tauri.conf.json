{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "st-imgslider",
  "version": "0.1.0",
  "identifier": "com.snaptask.slider",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SnapTask Image Slider",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset: https://asset.localhost http://asset.localhost https://drive.google.com https://*.googleusercontent.com; connect-src 'self' https://www.googleapis.com https://drive.google.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "shell": null,
    "dialog": null,
    "fs": null,
    "process": null,
    "opener": null
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
